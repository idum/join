<%= form_with(model: event) do |form| %>
  <% if event.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>

      <ul>
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :info, style: "display: block" %>
    <%= form.textarea :info %>
  </div>

  <div>
    <%= form.label :gif, style: "display: block" %>
    <%= form.textarea :gif %>
  </div>

  <div>
    <%= form.label :join_max, style: "display: block" %>
    <%= form.number_field :join_max %>
  </div>

  <div>
    <%= form.label :address, style: "display: block" %>
    <%= form.textarea :address %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
